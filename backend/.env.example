# ── Database ─────────────────────────────────────────────
DB_HOST=ep-tiny-tooth-atwvhkaa-pooler.c-9.us-east-1.aws.neon.tech
DB_PORT=5432
DB_USER=neondb_owner
DB_PASSWORD=npg_PSwNvCa31Ect
DB_NAME=neondb

PGSSLMODE=require
# ── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# ── AI Provider ──────────────────────────────────────────
# provider: "anthropic" | "openai" | "gemini" | "groq" | "openrouter" | "none"
# "none" (or an empty key) = every AI feature falls back gracefully.
#
# FREE options (sign up, copy key, paste below):
#   gemini  → https://aistudio.google.com/apikey        (free tier, has vision)
#   groq    → https://console.groq.com/keys             (free tier, has vision)
#   openrouter → https://openrouter.ai/settings/keys    (":free" models)
# Paid: anthropic → console.anthropic.com · openai → platform.openai.com
#
# AI_MODEL is optional — each provider has a sensible default
# (gemini-2.0-flash / llama-4-scout / gpt-4o / claude-sonnet-5).
# AI_BASE_URL is optional — overrides the provider's default endpoint.
AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=

# ── App ──────────────────────────────────────────────────
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
HIGH_VALUE_THRESHOLD=500
UPLOAD_DIR=./uploads
